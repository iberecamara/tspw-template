{
  "name": "tspw-template",
  "version": "1.0.0",
  "description": "Vanilla Playwright Test Automation Framework template",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --config=src/configs/playwright.config.ts --grep-invert @dev",
    "test:dev": "npx playwright test --config=src/configs/playwright.config.ts --grep @dev",
    "test:retry-failed": "npm test -- --last-failed --last-failed-file=artifacts/reports/playwright/test-results/.last-run.json",
    "test:pwui": "npm test -- --ui",
    "test:ui": "npm test -- --grep @ui",
    "test:pwui:ui": "npm test -- --ui --grep @ui",
    "test:api": "npm test --grep @api",
    "test:pwui:api": "npm test --ui --grep @api",
    "report:allure:generate": "ts-node -r tsconfig-paths/register src/utils/allure.utils.ts generate",
    "report:allure:open": "ts-node -r tsconfig-paths/register src/utils/allure.utils.ts open",
    "report:html:open": "ts-node -r tsconfig-paths/register src/utils/html-report.utils.ts open",
    "report:allure:export": "ts-node -r tsconfig-paths/register src/utils/allure.utils.ts export",
    "report": "ts-node -r tsconfig-paths/register src/utils/allure.utils.ts all",
    "clean:logs": "rimraf artifacts/logs/*",
    "clean:reports": "rimraf artifacts/reports/*",
    "clean": "npm run clean:logs && npm run clean:reports",
    "lint": "eslint src --config src/configs/eslint.config.mjs .",
    "lint:fix": "eslint src --fix --config src/configs/eslint.config.mjs .",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "lint:formatcheck": "npm run lint; npm run format:check",
    "typecheck": "tsc --noEmit",
    "codestandards": "npm run typecheck; npm run lint; npm run format:check"
  },
  "keywords": [],
  "author": "Iberê Camara",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "allure": "^3.14.3",
    "dotenv": "^17.4.2",
    "joi": "^18.2.1",
    "playwright-video": "^2.4.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "uuidv7": "^1.1.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "allure-playwright": "^3.10.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.5",
    "playwright": "^1.57.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}